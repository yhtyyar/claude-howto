{
  "name": "@qoder-enterprise/mcp-hook-runner",
  "version": "1.0.0",
  "description": "MCP Server for Hook Automation and Workflow Management in Qoder IDE",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
